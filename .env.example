# --- AI providers ---
# OpenAI — agent reasoning, image analysis, prompt translation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
VLM_MODEL=gpt-4o

# fal.ai — image generation/editing (FLUX Kontext) + image-to-video (Kling/Luma)
FAL_KEY=
FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/dev
FAL_IMAGE_EDIT_MODEL=fal-ai/flux-pro/kontext

# Legacy/optional only. Missing reel shots are generated through fal.ai.
GEMINI_API_KEY=

# --- Optional: direct generative video providers (covered by FAL_KEY too) ---
RUNWAY_API_KEY=
LUMA_API_KEY=
I2V_PROVIDER=stub

# --- Optional: audio ---
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# --- Server config ---
DATABASE_URL=sqlite:///./storage_data/realstate.db
STORAGE_ROOT=./storage_data
AUDIO_LIBRARY_ROOT=./audio_library
CORS_ORIGINS=http://localhost:3000

# Model defaults
OPENAI_VISION_MODEL=gpt-4o
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
