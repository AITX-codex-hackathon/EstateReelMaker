# --- AI providers ---
# OpenAI — agent reasoning, image analysis, prompt translation
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.5
OPENAI_MODEL=gpt-5.5
VLM_MODEL=gpt-5.5
OPENAI_ANALYZER_MODEL=gpt-5.5
OPENAI_STORYBOARD_MODEL=gpt-5.5
OPENAI_PROMPT_TRANSLATOR_MODEL=gpt-5.5
OPENAI_PHOTO_SELECTOR_MODEL=gpt-5.5
OPENAI_MODEL_FALLBACKS=gpt-5.2,gpt-5,gpt-4o
PHOTO_SELECTION_THRESHOLD=20
PHOTO_SELECTION_LIMIT=24

# fal.ai — image generation/editing (FLUX Kontext) + image-to-video (Kling/Luma)
FAL_KEY=
FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/dev
FAL_IMAGE_EDIT_MODEL=fal-ai/flux-pro/kontext
FAL_RENDER_CONCURRENCY=3

# Legacy/optional only. Missing reel shots are generated through fal.ai.
GEMINI_API_KEY=

# --- Optional: direct generative video providers (covered by FAL_KEY too) ---
RUNWAY_API_KEY=
LUMA_API_KEY=
I2V_PROVIDER=fal

# --- Optional: audio ---
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# --- Server config ---
DATABASE_URL=sqlite:///./storage_data/realstate.db
STORAGE_ROOT=./storage_data
AUDIO_LIBRARY_ROOT=./audio_library
CORS_ORIGINS=http://localhost:3000

# Model defaults
OPENAI_VISION_MODEL=gpt-5.5
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
