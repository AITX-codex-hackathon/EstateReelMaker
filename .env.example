# --- AI providers ---
# OpenAI — agent reasoning, image analysis, prompt translation
OPENAI_API_KEY=

# fal.ai — image generation/editing (FLUX Kontext) + image-to-video (Kling/Luma)
FAL_KEY=

# Google Gemini — Nano Banana Pro (gemini-3-pro-image-preview) — alternative to fal for image gen
GEMINI_API_KEY=

# --- Optional: direct generative video providers (covered by FAL_KEY too) ---
RUNWAY_API_KEY=
LUMA_API_KEY=

# --- Optional: audio ---
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# --- Server config ---
DATABASE_URL=sqlite:///./storage_data/reelstate.db
STORAGE_ROOT=./storage_data
AUDIO_LIBRARY_ROOT=./audio_library
CORS_ORIGINS=http://localhost:3000

# Model defaults
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
