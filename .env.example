# --- AI providers ---
# Claude — agent reasoning, image analysis, prompt translation
ANTHROPIC_API_KEY=

# Google Gemini — Nano Banana (gemini-2.5-flash-image) for image gen/edit/crop
GOOGLE_API_KEY=

# --- Optional generative video for hero shots ---
RUNWAY_API_KEY=
LUMA_API_KEY=

# --- Optional audio ---
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# --- Server config ---
DATABASE_URL=sqlite:///./storage_data/realstate.db
STORAGE_ROOT=./storage_data
AUDIO_LIBRARY_ROOT=./audio_library
CORS_ORIGINS=http://localhost:3000

# Model defaults
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_VISION_MODEL=claude-sonnet-4-6
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
